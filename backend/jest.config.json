{
  "testEnvironment": "node",
  "testMatch": ["**/__tests__/**/*.test.js"],
  "collectCoverageFrom": [
    "services/**/*.js",
    "controllers/**/*.js",
    "middleware/**/*.js",
    "!**/node_modules/**"
  ],
  "coverageThreshold": {
    "global": {
      "lines": 60,
      "functions": 60
    }
  },
  "testTimeout": 15000,
  "verbose": true
}
