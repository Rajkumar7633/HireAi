# Core
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority

# Judge0 (default — free public CE, no key required)
JUDGE0_URL=https://ce.judge0.com
# Option B: RapidAPI (higher limits, requires key)
# JUDGE0_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_KEY=YOUR_RAPIDAPI_KEY

# Piston fallback (optional — public API now requires auth as of 2026)
# PISTON_URL=http://localhost:2000/api/v2/execute
# PISTON_API_KEY=
# CODE_EXECUTOR=judge0

# Email Service Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="HireAI <no-reply@yourapp.com>"

# Alternative Email Service Configuration
EMAIL_SERVICE_HOST=smtp.gmail.com
EMAIL_SERVICE_PORT=587
EMAIL_SERVICE_USER=your-email@gmail.com
EMAIL_SERVICE_PASS=your-app-password

# Security Configuration
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-encryption-key-here

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379

# OpenAI Configuration (for AI features)
OPENAI_API_KEY=your-openai-api-key

# Twilio Configuration (for SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Analytics Configuration
GOOGLE_ANALYTICS_ID=your-ga-id

# Development/Production
NODE_ENV=development

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=hireai/interviews

# College meetings — LiveKit SFU (recommended for 500+ students)
# Free tier: https://cloud.livekit.io — webinar mode: host publishes, students watch
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=wss://your-project.livekit.cloud
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
# Fallback when LiveKit is not configured (public Jitsi — lower limits than self-hosted)
# NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si

# Feature flags (optional)
# NEXT_PUBLIC_LOGIN_3D_MODEL=
# NEXT_PUBLIC_LOGIN_3D_SCALE=1.4
# NEXT_PUBLIC_LOGIN_3D_ROT_Y=0.3
# NEXT_PUBLIC_LOGIN_3D_POS_Y=-0.2
# NEXT_PUBLIC_LOGIN_3D_USE_CODER=false
# NEXT_PUBLIC_LOGIN_3D_USE_STUDENTS=true
