# ─── HireAI Production Environment Configuration ───────────────────────────────
# For Vercel (frontend) + Render (backend) deployment
# Copy NEXT_PUBLIC_* variables to Vercel environment variables
# Copy non-NEXT_PUBLIC_* variables to Render environment variables
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database Configuration ───────────────────────────────────────────────────
# Production (MongoDB Atlas)
MONGODB_URI=mongodb+srv://RajKumar7633:Raj@76330Raj@cluster0.kd5li4c.mongodb.net/?appName=Cluster0

# ─── Redis Configuration ───────────────────────────────────────────────────────
# Production (Redis Cloud)
REDIS_URL=redis://default:<password>@<host>:<port>

# ─── Authentication & Security ───────────────────────────────────────────────────
JWT_SECRET=your-production-jwt-secret-here
ENCRYPTION_KEY=your-production-encryption-key-here

# ─── Server Configuration ───────────────────────────────────────────────────────
# Frontend (Vercel) - Set these in Vercel
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Backend (Render) - Set these in Render
BACKEND_PORT=5001
NEXT_PUBLIC_BACKEND_URL=https://your-backend.onrender.com

# ─── Email Service Configuration ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="HireAI <no-reply@yourapp.com>"

# Alternative Email Service Configuration
EMAIL_SERVICE_HOST=smtp.gmail.com
EMAIL_SERVICE_PORT=587
EMAIL_SERVICE_USER=your-email@gmail.com
EMAIL_SERVICE_PASS=your-app-password
EMAIL_TEST_TO=your-email@gmail.com

# ─── AI / Gemini Configuration ─────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro
ENABLE_AI_SDK=true
AI_SHORTLIST_THRESHOLD=75
AI_MIN_ATS_SCORE=65

# Optional: OpenAI as fallback
OPENAI_API_KEY=your-openai-api-key

# ─── ML Service Configuration ───────────────────────────────────────────────────
ML_SERVICE_URL=https://your-ml-service.onrender.com

# ─── Cloudinary Configuration ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_FOLDER=hireai/interviews

# ─── Judge0 Code Execution ───────────────────────────────────────────────────────
# Option A: Public CE instance (no API key required)
JUDGE0_URL=https://ce.judge0.com
# Option B: RapidAPI (recommended for reliability & higher limits)
# JUDGE0_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_KEY=YOUR_RAPIDAPI_KEY

# ─── LiveKit (college Teams-style meetings) ────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ─── Stripe Configuration ───────────────────────────────────────────────────────
# Frontend (Vercel) - Set these in Vercel
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
NEXT_PUBLIC_RECRUITER_PRO_PRICE=your-recruiter-pro-price-id
NEXT_PUBLIC_STUDENT_PLUS_PRICE=your-student-plus-price-id

# Backend (Render) - Set these in Render
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
BILLING_ENABLED=1
RECRUITER_PRO_PRICE=your-recruiter-pro-price-id
STUDENT_PLUS_PRICE=your-student-plus-price-id

# ─── Branding Configuration ────────────────────────────────────────────────────
# Frontend (Vercel) - Set these in Vercel
NEXT_PUBLIC_COMPANY_NAME=HireAI
NEXT_PUBLIC_COMPANY_WEBSITE=https://your-app.vercel.app
NEXT_PUBLIC_BRAND_COLOR=#6d28d9
NEXT_PUBLIC_ACCENT_COLOR=#eef2ff

# ─── Feature Flags ───────────────────────────────────────────────────────────────
# Frontend (Vercel) - Set these in Vercel
NEXT_PUBLIC_ADMIN_ENABLED=1
# Backend (Render) - Set these in Render
ADMIN_ALLOW_SELF_SIGNUP=1
ANALYTICS_CACHE=1

# ─── File Upload Configuration ───────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx
UPLOAD_DIR=./uploads

# ─── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=warn

