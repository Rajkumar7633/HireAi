# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Next.js build output ─────────────────────────────────────────────────────
.next
out

# ─── Build artifacts ──────────────────────────────────────────────────────────
build
dist

# ─── Environment files (never bake secrets into image) ────────────────────────
.env
.env.*
!.env.example

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
server.log

# ─── Uploads (mounted as volume, not baked in) ────────────────────────────────
uploads/

# ─── Git ──────────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── Testing / Coverage ───────────────────────────────────────────────────────
coverage
__tests__
*.test.js
*.spec.js

# ─── Documentation ────────────────────────────────────────────────────────────
README.md
CHANGELOG.md
docs/

# ─── Docker meta (not needed inside image) ────────────────────────────────────
.dockerignore
docker-compose*.yml
